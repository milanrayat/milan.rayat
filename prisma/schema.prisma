// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Profile {
  id        Int    @id @default(autoincrement())
  name      String
  title     String
  tagline   String
  uvp       String
  email     String
  linkedin  String
  calendly  String
  company   String
}

model Metric {
  id       Int    @id @default(autoincrement())
  value    String
  label    String
  category String
  order    Int    @default(0)
}

model Highlight {
  id       Int    @id @default(autoincrement())
  slug     String @unique
  category String
  headline String
  body     String
  order    Int    @default(0)
}

model Skill {
  id       Int    @id @default(autoincrement())
  category String
  value    String
  order    Int    @default(0)
}

model CaseStudy {
  id        Int               @id @default(autoincrement())
  slug      String            @unique
  title     String
  tagline   String
  tags      String
  situation String
  task      String
  actions   String
  result    String
  order     Int               @default(0)
  metrics   CaseStudyMetric[]
}

model CaseStudyMetric {
  id          Int       @id @default(autoincrement())
  value       String
  label       String
  order       Int       @default(0)
  caseStudy   CaseStudy @relation(fields: [caseStudyId], references: [id])
  caseStudyId Int
}

model ContactSubmission {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}
